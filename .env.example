# Optional override for the PulseChain RPC endpoint used by both
# the wagmi transport and viem chain config. Defaults to https://rpc.pulsechain.com.
NEXT_PUBLIC_PULSECHAIN_RPC_URL=

# WalletConnect Cloud project ID.
# Obtain a free one at https://cloud.reown.com (formerly WalletConnect Cloud).
# Web: optional — when set, adds QR pairing for mobile wallets alongside injected.
# Desktop (Tauri): REQUIRED — browser extension injection does not work in a
#   webview, so WalletConnect is the primary connection method on desktop.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Optional override for the Blockscout-compatible PulseChain explorer API
# used by the approval discovery pipeline. Defaults to
# https://api.scan.pulsechain.com/api. Must implement the Etherscan-compat
# `?module=logs&action=getLogs` endpoint with topic0 / topic1 filters.
NEXT_PUBLIC_PULSECHAIN_EXPLORER_API=

# Optional override for the Ethereum mainnet RPC endpoint used by both
# the wagmi transport and viem chain config. Defaults to the viem built-in
# mainnet transport (cloudflare-eth.com). Set this to a private RPC
# (e.g. Alchemy, Infura) for higher rate limits and reliability.
NEXT_PUBLIC_MAINNET_RPC_URL=

# Optional override for the Etherscan-compatible API used by the approval
# discovery pipeline on Ethereum mainnet. Defaults to
# - https://api.etherscan.io/v2/api when NEXT_PUBLIC_ETHERSCAN_API_KEY is set
# - https://eth.blockscout.com/api when no key is set
# You can point this to any Etherscan-compatible endpoint.
NEXT_PUBLIC_MAINNET_EXPLORER_API=

# Etherscan API key. Optional. When set, Ethereum discovery uses Etherscan v2.
# When omitted, discovery automatically falls back to Blockscout on mainnet.
# Obtain at https://etherscan.io/myapikey.
NEXT_PUBLIC_ETHERSCAN_API_KEY=

# Canonical public URL of the deployment (e.g. https://revoke.pls).
# Used by SEO metadata, Open Graph/Twitter card absolute URLs, and the
# canonical tag. Defaults to https://revoke.pls (the production domain).
# Set this to your own origin for preview/staging deploys so previews do
# not advertise the production canonical.
NEXT_PUBLIC_SITE_URL=
