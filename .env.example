# Optional override for the PulseChain RPC endpoint used by both
# the wagmi transport and viem chain config. Defaults to https://rpc.pulsechain.com.
NEXT_PUBLIC_PULSECHAIN_RPC_URL=

# Optional WalletConnect Cloud project ID.
# Obtain a free one at https://cloud.reown.com (formerly WalletConnect Cloud).
# When set, the "WalletConnect" option appears in the connect menu so mobile
# wallets can pair via QR. When unset, only the injected wallet option is shown.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Optional canonical public URL (e.g. https://pulse-revoke.app).
# Used by SEO metadata, Open Graph, Twitter cards, and the canonical tag.
# Defaults to the placeholder defined in src/lib/site.ts.
NEXT_PUBLIC_SITE_URL=
