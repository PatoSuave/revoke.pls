# Optional override for the PulseChain RPC endpoint used by both the wagmi
# transport and viem chain config. Defaults to https://rpc.pulsechain.com.
NEXT_PUBLIC_PULSECHAIN_RPC_URL=

# Optional override for the BSC / BNB Smart Chain RPC endpoint used by both
# the wagmi transport and viem chain config. Defaults to the public BNB Chain
# RPC at https://bsc-dataseed.bnbchain.org. Use a private RPC for production
# reliability; historical approval discovery still uses BscScan logs API.
NEXT_PUBLIC_BSC_RPC_URL=

# WalletConnect Cloud project ID.
# Obtain a free one at https://cloud.reown.com (formerly WalletConnect Cloud).
# When set, adds QR pairing for mobile wallets alongside injected wallets.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Optional override for the Blockscout-compatible PulseChain explorer API
# used by the approval discovery pipeline. Defaults to
# https://api.scan.pulsechain.com/api. Must implement the Etherscan-compatible
# ?module=logs&action=getLogs endpoint with topic0 / topic1 filters.
NEXT_PUBLIC_PULSECHAIN_EXPLORER_API=

# Optional override for the BscScan logs API used by BSC approval discovery.
# Defaults to https://api.bscscan.com/api. The scanner uses logs/getLogs for
# BEP-20 Approval and BEP-721/BEP-1155 ApprovalForAll discovery instead of
# public RPC eth_getLogs history scans.
NEXT_PUBLIC_BSC_EXPLORER_API_URL=https://api.bscscan.com/api

# BscScan API key. Required for BSC historical approval discovery with the
# default BscScan endpoint. Do not commit real keys.
NEXT_PUBLIC_BSCSCAN_API_KEY=

# Canonical public URL of the deployment (e.g. https://revoke-pls.vercel.app).
# Used by SEO metadata, Open Graph/Twitter card absolute URLs, and the
# canonical tag. Defaults to https://revoke.pls (the production domain).
# Use a full URL with https://. Host-only values are normalized defensively.
# Set this to your own origin for preview/staging deploys so previews do not
# advertise the production canonical.
NEXT_PUBLIC_SITE_URL=https://revoke-pls.vercel.app
